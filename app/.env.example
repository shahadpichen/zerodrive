# ZeroDrive Frontend Environment Variables

# Backend API URL
REACT_APP_API_URL=http://localhost:3001/api

# CRITICAL: PBKDF2 salt for encrypting encryption keys in sessionStorage
#
# ⚠️  IMPORTANT WARNINGS:
# 1. This value must be generated ONCE before first deployment
# 2. This value must NEVER change after users start using the app
# 3. If this changes, all existing users' encrypted keys become undecryptable
# 4. Keep this value backed up with your infrastructure secrets
# 5. Use the same value across dev/staging/prod environments
#
# To generate a new salt (ONLY for new deployments):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Example: Ax/ogXwJkHrzj9+HXqyISBKKTZtt7YQSXaMKgnuhzR8=
REACT_APP_PBKDF2_SALT=your-generated-salt-here
