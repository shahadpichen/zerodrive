# ZeroDrive Frontend Environment Variables

# Backend API URL
REACT_APP_API_URL=http://localhost:3001/api

# PBKDF2 Salt for RSA Private Key Encryption in IndexedDB
# Used to derive encryption key from mnemonic for securing RSA private keys
# IMPORTANT: Change this value in production and keep it secret
REACT_APP_RSA_PBKDF2_SALT=your-rsa-key-salt-change-in-production
