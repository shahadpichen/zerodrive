# ZeroDrive Backend Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3001
HOST=localhost

# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_NAME=zerodrive
DB_USER=zerodrive_app
DB_PASSWORD=localdev123
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=debug

# Security (generate these for production)
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-32-byte-encryption-key-here
EMAIL_HASH_SALT=your-random-salt-string-here

# MinIO Configuration (for future object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zerodrive-files
MINIO_USE_SSL=false

# Mailgun Email Configuration
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_DOMAIN=sandbox...mailgun.org
MAILGUN_FROM_NAME=ZeroDrive
MAILGUN_FROM_EMAIL=postmaster@sandbox...mailgun.org
MAILGUN_WEBHOOK_SIGNING_KEY=your-webhook-signing-key-here

# Application URL (for email links)
APP_URL=http://localhost:5173